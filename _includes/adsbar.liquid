<div style="height:60px;"></div>

<a href="https://ko-fi.com/ctrlall" class="support-cta-button" target="_blank" rel="noopener noreferrer">
  <img src="https://storage.ko-fi.com/cdn/logomarkLogo.png" alt="Ko-fi logo" class="kofi-logo" loading="lazy">
  <span>Support us</span>
</a>

<div style="height: 10px;"></div>

<div class="adsbar-content" style="width:100%; max-width:728px; margin:auto;">
  <div class="ads-label" aria-hidden="true">Sponsored</div>
  <div id="ad-wrapper" style="width:100%; min-width:300px;">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-6596712504858429"
         data-ad-slot="5978194952"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
</div>

<noscript>
  <div class="ad-fallback">Ad content not available. Please enable JavaScript.</div>
</noscript>

<script>
  // Initialize AdSense only once, after the page has fully loaded

  window.addEventListener('load', function() {
    setTimeout(function() {
      const adWrapper = document.getElementById('ad-wrapper');
      if (adWrapper && adWrapper.offsetWidth > 0) {
        try {
          (adsbygoogle = window.adsbygoogle || []).push({});
          console.log("✅ AdSense ad initialized after layout delay");
        } catch (e) {
          console.error("❌ AdSense push failed:", e);
        }
      } else {
        console.warn("⚠️ Ad wrapper still has no width, ad not pushed");
      }
    }, 300); // wait 300ms after load
  });


  function openKofiPopup(e) {
    e.preventDefault();
    const popup = document.getElementById('kofi-popup');
    if (popup) popup.style.display = 'block';
  }

  function closeKofiPopup() {
    const popup = document.getElementById('kofi-popup');
    if (popup) popup.style.display = 'none';
  }
</script>
