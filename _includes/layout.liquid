<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ title }} – CTRL All</title>

  {% if page.canonical %}
    <link rel="canonical" href="{{ page.canonical }}">
  {% else %}
    <link rel="canonical" href="{{ page.url }}">
  {% endif %}

  <meta name="ctrlall-source" content="{{ page.asset_id }}">
  <meta name="description" content="{{ description | default: 'Empowering learners with open-source tools and ethical guidance.' }}">
  <meta name="author" content="Steve Williams – CTRL All">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <meta name="robots" content="index, follow">

  {% assign page_image = image | default: "/assets/images/Ctrl All logo blue.svg" %}

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }} – CTRL All">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="{{ page_image | url }}">
  <meta property="og:url" content="{{ page.url }}">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title | escape }}",
    "description": "{{ description | escape }}",
    "url": "{{ page.url }}",
    "image": "{{ page_image | url }}",
    "author": {
      "@type": "Organization",
      "name": "CTRL All"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CTRL All",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ '/assets/logo.png' | url }}"
      }
    }
    {% if date %}, "datePublished": "{{ date }}"{% endif %}
    {% if last_modified %}, "dateModified": "{{ last_modified }}"{% endif %}
  }
  </script>

  <meta name="google-adsense-account" content="ca-pub-6596712504858429">

  {% if page.url == '/coming-soon/' %}
  <meta name="robots" content="noindex">
  {% endif %}


  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
</head>

<body>

  {% include "mobile-overlay.liquid" %}

  <noscript>
    <div class="noscript-warning">JavaScript is required for full site functionality.</div>
  </noscript>

  <header class="topbar">
    <button id="navbar-toggle" class="sidebar-toggle" aria-label="Toggle sidebar">☰</button>
    {% include "topbar.liquid" %}
  </header>

  <div class="layout-wrapper">
    <nav class="sidebar-wrapper">
      <div id="navbar-content" class="navbar-collapse">
        {% include "navbar.liquid", page: page %}
      </div>
    </nav>

    <main class="content-wrapper">
      <div class="content">
        <section id="main-content">
          {{ content }}
        </section>
      </div>
    </main>

    <aside class="adsbar-wrapper">
      {% include "adsbar.liquid" %}
    </aside>
  </div>

  <div id="gif-tooltip" class="gif-tooltip">
    <img src="" alt="Tooltip GIF">
  </div>

  <div id="share-dropdown" class="dropdown-content">
    <a href="javascript:void(0)" onclick="copyPageLink(this)" style="position:relative;">
      🔗Copy Link <span class="copy-tooltip">Copied!</span>
    </a>
    <a href="javascript:void(0)" onclick="emailCurrentPage(event)">📧Email this page</a>
    <a id="linkedin-share" target="_blank" href="https://www.linkedin.com/sharing/share-offsite/?url={{ page.url }}">
      <img src="{{ '/assets/images/topbar/linkedin.png' | url }}" alt="Linkedin">
    </a>
    <a id="facebook-share" target="_blank" href="https://www.facebook.com/sharer/sharer.php?u={{ page.url }}">
      <img src="{{ '/assets/images/topbar/facebook.png' | url }}" alt="Facebook">
    </a>
    <a id="reddit-share" target="_blank" href="https://www.reddit.com/submit?url={{ page.url }}&title=CTRL%20All">
      <img src="{{ '/assets/images/topbar/reddit.png' | url }}" alt="Reddit">
    </a>
    <a id="bluesky-share" target="_blank" href="https://bsky.app/intent/compose?text=CTRL%20All%20{{ page.url }}">
      <img src="{{ '/assets/images/topbar/bluesky.png' | url }}" alt="Bluesky">
    </a>
    <a id="threads-share" target="_blank" href="https://www.threads.net/intent/post?text=CTRL%20All%20{{ page.url }}">
      <img src="{{ '/assets/images/topbar/threads.png' | url }}" alt="Threads">
    </a>
  </div>

  <div id="imageModal" class="modal">
    <span class="close">&times;</span>
    <img id="modalImage" class="modal-content" src="" alt="">
  </div>

  <footer class="site-footer">
    © 2025 Ctrl All. All rights reserved. For reuse or licensing inquiries, please <a href="{{ '/contact/' | url }}">contact us</a>.
  </footer>

  <script src="{{ '/js/main.js' | url }}"></script>
  <script>
    function copyPageLink(el) {
      const url = window.location.href;
      navigator.clipboard.writeText(url)
        .then(() => {
          const tooltip = el.querySelector(".copy-tooltip");
          tooltip.classList.add("visible");
          setTimeout(() => {
            tooltip.classList.remove("visible");
          }, 1500);
        })
        .catch(err => console.error("Copy failed:", err));
    }

    function emailCurrentPage(event) {
      event.preventDefault();
      const subject = "Check out this page";
      const body = "Here's a link I wanted to share with you:\n\n" + window.location.href;
      const mailtoLink = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailtoLink;
    }
  </script>

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>

  <div id="glossary-tooltip" hidden></div>

  <!-- CTRL All asset ID: {{ page.asset_id }} -->
</body>
</html>
