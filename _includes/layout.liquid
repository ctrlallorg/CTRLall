<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ title }} – Ctrl All</title>

  {% if page.canonical %}
    <link rel="canonical" href="{{ page.canonical }}">
  {% else %}
    <link rel="canonical" href="{{ page.url }}">
  {% endif %}

  <meta name="ctrlall-source" content="{{ page.asset_id }}">
  <meta name="description" content="{{ description }}">
  <meta name="author" content="Steve Williams – Ctrl All">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <meta name="robots" content="index, follow">

  {% assign page_image = image | default: "/assets/images/Ctrl All logo blue.svg" %}

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }} – Ctrl All">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="https://stevewilliams87.github.io/CTRLall/assets/images/Ctrl-All-logo-og.png">
  <meta property="og:url" content="{{ page.url }}">

  {% if page.difficultyLevels %}
  {% for diff in page.difficultyLevels %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "{{ title | escape }}",
      "headline": "{{ title | escape }}",
      "description": "{{ description | escape }} {{ diff.description }}",
      "url": "{{ page.url }}{{ diff.urlSuffix }}",
      "image": "{{ page_image | url }}",
      "educationalLevel": "{{ diff.level }}",
      "publisher": {
        "@type": "Organization",
        "name": "Ctrl All",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ '/assets/logo.png' | url }}"
        }
      }
      {% if date %}, "datePublished": "{{ date }}"{% endif %}
      {% if last_modified %}, "dateModified": "{{ last_modified }}"{% endif %}
    }
    </script>
  {% endfor %}
{% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    {% case page.type %}
      {% when "about" %}
        "@type": "AboutPage",
      {% when "contact" %}
        "@type": "ContactPage",
      {% when "privacy" %}
        "@type": "PrivacyPolicy",
      {% else %}
        "@type": "WebPage",
    {% endcase %}
    "name": "{{ title | escape }}",
    "headline": "{{ title | escape }}",
    "description": "{{ description | escape }}",
    "url": "{{ page.url }}",
    "image": "{{ page_image | url }}",
    "publisher": {
      "@type": "Organization",
      "name": "Ctrl All",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ '/assets/logo.png' | url }}"
      }
    }
    {% if date %}, "datePublished": "{{ date }}"{% endif %}
    {% if last_modified %}, "dateModified": "{{ last_modified }}"{% endif %}
  }
  </script>
{% endif %}

  <meta name="google-adsense-account" content="ca-pub-6596712504858429">

  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LHDJ9W7GWZ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LHDJ9W7GWZ');
  </script>
</head>

<body>

  {% include "mobile-overlay.liquid" %}

  <noscript>
    <div class="noscript-warning">JavaScript is required for full site functionality.</div>
  </noscript>

<header class="topbar">
    <button id="navbar-toggle" class="sidebar-toggle" aria-label="Toggle sidebar">☰</button>
    {% include "topbar.liquid" %}
  </header>

<!-- PAGE CONTAINER WRAPPER (includes adsbar with sidebar and main column) -->
<div class="page-container">

  <!-- LAYOUT WRAPPER -->
  <div class="layout-wrapper">

    <!-- FIXED LEFT SIDEBAR -->
    <nav class="sidebar-wrapper">
      <div id="navbar-content" class="navbar-collapse">
        {% include "navbar.liquid", page: page %}
      </div>
    </nav>

    <!-- MAIN CONTENT COLUMN -->
    <div class="main-column">
      <main class="content-wrapper">
        <div class="content">
          <section id="main-content">
            {{ content }}

            {% if image and hotspots %}
            <div class="overlay-container">
              <img src="{{ image.src }}" alt="Hotspot image" class="base-image">
              {% for spot in hotspots %}
                <div class="hotspot rich-tooltip-trigger"
                     data-tooltip-id="{{ spot.tooltip }}"
                     style="top:{{ spot.top | pxToPercent: 'height', image }}%; 
                            left:{{ spot.left | pxToPercent: 'width', image }}%;">
                </div>
              {% endfor %}
            </div>
            {% endif %}
          </section>
        </div>
      </main>
    </div>

  </div>

  <!-- FIXED RIGHT ADSBAR (MUST BE OUTSIDE layout-wrapper) -->
  <aside class="adsbar-wrapper">
    {% include "adsbar.liquid" %}
  </aside>

<!-- Closing Page container div -->
</div>   

  <!-- IMAGE MODAL -->
  <div id="imageModal" class="modal">
    <span class="close">&times;</span>
    <img id="modalImage" class="modal-content" src="" alt="">
  </div>




  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="social-icons image-adjacent">
      <a href="/privacy-policy/">Privacy Policy</a>
      © 2025 Ctrl All. All rights reserved. For reuse or licensing inquiries 
      <a href="{{ '/contact/' | url }}">contact us</a>
      <a href="https://www.facebook.com/profile.php?id=61583244572128" target="_blank" aria-label="Facebook">
        <img src="{{ '/assets/images/topbar/facebook.png' | url }}" alt="Facebook icon">
      </a>
      <a href="https://www.linkedin.com/company/ctrl-all-org/" target="_blank" aria-label="LinkedIn">
        <img src="{{ '/assets/images/topbar/linkedin.png' | url }}" alt="LinkedIn icon">
      </a>
    </div>
  </footer>

<script src="/js/main.js"></script>
  <script>
    function copyPageLink(el) {
      const url = window.location.href;
      navigator.clipboard.writeText(url)
        .then(() => {
          const tooltip = el.querySelector(".copy-tooltip");
          tooltip.classList.add("visible");
          setTimeout(() => {
            tooltip.classList.remove("visible");
          }, 1500);
        })
        .catch(err => console.error("Copy failed:", err));
    }

    function emailCurrentPage(event) {
      event.preventDefault();
      const subject = "Check out this page";
      const body = "Try this page from Ctrl All:\n\n" + window.location.href;
      const mailtoLink = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailtoLink;
    }
  </script>

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>

  <div id="glossary-tooltip" hidden></div>

  <!-- Ctrl All asset ID: {{ page.asset_id }} -->
</body>
</html>
